{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "VisionOS",
  "version": "0.1.0",
  "identifier": "com.jarvis.visionos",
  "build": {
    "frontendDist": "../build/client",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev:raw",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VisionOS",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:* http://localhost:* ipc: http://ipc.localhost; connect-src 'self' http://127.0.0.1:* http://localhost:* https:; img-src 'self' data: https: http:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
