# VisionOS / Jarvis — template for local setup.
# Copy to `.env` and edit:  cp .env.example .env
#
# Loaded by src/lib/server/env.ts on server boot (before config.js).
# Bootstrap-only in .env (everything else → Settings UI, persisted in SQLite):
#   PORT, DATABASE_PATH, and optional API keys (GROQ_API_KEY, OPENROUTER_API_KEY, etc.)
# On first run, the database seeds code defaults so a fresh clone works without copying this file.

# LLM provider: local | openai | gemini | groq | openrouter | cerebras | cursor
# LLM_PROVIDER=local

# llama.cpp / Ollama (OpenAI-compatible)
LLM_BASE_URL=http://localhost:11434/v1
LLM_SLOTS_ENABLED=true
LLM_SLOT_ID=0
LLM_MODEL=gemma-4-E4B-it-Q4_K_M.gguf
LLM_CONTEXT=131072

# API keys — OpenAI-compatible providers (any one works as fallback via LLM_API_KEY)
# LLM_API_KEY=gsk_...
# OPENROUTER_API_KEY=sk-or-...
# LLM_MODEL=openrouter/free
# GROQ_API_KEY=gsk_...
# CEREBRAS_API_KEY=csk_...
# LLM_MODEL=gpt-oss-120b
# OPENAI_API_KEY=sk-...
# CURSOR_API_KEY=cursor_...
# LLM_PROVIDER=cursor
# LLM_MODEL=composer-2.5
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Gemini OpenAI-compatible base URL (set automatically when choosing Gemini in Settings):
# https://generativelanguage.googleapis.com/v1beta/openai
# LLM_MODEL=gemini-2.0-flash

# Directory the agent can read/write files in
WORKSPACE_DIR=/var/home/janroenz/Desktop/projects

# VisionOS data (defaults to visionos/data/jarvis.db if unset)
# Reuse gemma-agent DB during migration:
# DATABASE_PATH=../../gemma-agent/data/jarvis.db
# DATABASE_PATH=data/jarvis.db

# SearXNG (auto-started on server boot and via `npm run dev`; set SEARXNG_AUTO_START=false to disable)
SEARXNG_API_BASE=http://localhost:8080
# SEARXNG_AUTO_START=false
SEARXNG_NUM_RESULTS=5
SEARXNG_CATEGORIES=general
SEARXNG_ALLOWED_ENGINES=google,bing,brave,duckduckgo,startpage,qwant,mojeek
# SEARXNG_ENGINES=google,brave,bing
# SEARXNG_USE_FIXED_ENGINES=true
# SEARXNG_LANGUAGE=en
# SEARXNG_SAFESEARCH=0
# SEARXNG_API_KEY=
# SEARXNG_FETCH_PAGES=5
# SEARXNG_FETCH_MAX_CHARS=20000
# SEARXNG_FETCH_CONCURRENCY=3

# Deep research mode
# DEEP_RESEARCH_SEARCH_TIMEOUT_MS=12000
# DEEP_RESEARCH_FETCH_CONCURRENCY=3
# DEEP_RESEARCH_SYNTHESIS_MAX_TOKENS=4096
# DEEP_RESEARCH_ENGINES_PER_SEARCH=2
# DEEP_RESEARCH_SUPPLEMENTAL_ENGINE_SEARCH=true
# WEB_SEARCH_MAX_PER_TURN=2
# WEB_SEARCH_AUTO_SAVE_TO_BRAIN=true
# WEB_SEARCH_BRAIN_RECALL_BEFORE_SEARCH=true
# WEB_SEARCH_BRAIN_RECALL_MIN_SCORE=0.32

# Context management
CONTEXT_RESERVE_TOKENS=4096
COMPACT_KEEP_RECENT=6
AUTO_COMPACT_PERCENT=60
MINIFY_ENABLED=true
# MINIFY_SEARCH_MAX_RESULTS=5
# MINIFY_SEARCH_SNIPPET_CHARS=500
# MINIFY_FILE_READ_MAX_CHARS=12000
# FILE_READ_MAX_BYTES=512000
# MINIFY_BASH_MAX_CHARS=1500
# MINIFY_ASSISTANT_MAX_CHARS=4000

# Agent evolution (core memory + skills)
EVOLUTION_PROMPT_MAX_MEMORIES=5
EVOLUTION_PROMPT_MAX_SKILLS=3
EVOLUTION_PROMPT_MIN_IMPORTANCE=4
EVOLUTION_RECALL_MAX_RESULTS=8
EVOLUTION_REFLECT_MAX_MEMORIES=3
EVOLUTION_REFLECT_MAX_SKILLS=2
EVOLUTION_REFLECT_MIN_IMPORTANCE=4
BRAIN_SEMANTIC_ENABLED=true
# BRAIN_SEMANTIC_MODEL=Xenova/all-MiniLM-L6-v2
# BRAIN_SEMANTIC_MIN_SCORE=0.2

EVOLUTION_MAX_MEMORIES=5
EVOLUTION_MAX_SKILLS=3
EVOLUTION_MEMORY_MAX_CHARS=300
EVOLUTION_SKILL_MAX_CHARS=500
EVOLUTION_REFLECT_TURNS=12
EVOLUTION_AUTO_REFLECT=true
EVOLUTION_AUTO_REFLECT_MIN_TURNS=2
EVOLUTION_AUTO_REFLECT_DEBOUNCE_MS=300000
EVOLUTION_COMPRESS_ON_SAVE=true
EVOLUTION_COMPRESS_STYLE=telegraph
EVOLUTION_COMPRESS_MAX_CHARS=120

# Universal syntax check (tree-sitter + Vue SFC markup)
CODE_CHECK_SYNTAX_ENABLED=true
# CODE_CHECK_MAX_FILE_BYTES=524288

# AST-first read gate
AST_READ_GATE_ENABLED=true
# AST_READ_REDIRECT=true
# AST_MAX_NODES=80
# AST_MAX_DEPTH=6
# AST_MAX_OUTLINE_SYMBOLS=60

# SvelteKit / adapter-node listen port (dev uses vite.config port 5173)
PORT=5173

# Per-conversation debug transcripts (full agent trace as JSONL)
# TRANSCRIPT_LOG_ENABLED=true
# TRANSCRIPT_DIR=data/transcripts
# TRANSCRIPT_MAX_FIELD_CHARS=0

# Agent
# AGENT_LOOP_V2=true
# PROMPT_COMPACT_MODE=true
# AGENT_REQUIRE_WEB_RESEARCH=true
# INTENT_ASSESSMENT_LLM=true
# INTENT_ASSESSMENT_ENABLED=true
# INTENT_ASSESSMENT_HEURISTIC_FIRST=true
# INTENT_ASSESSMENT_MAX_TOKENS=256
# NEXT_MOVE_PLANNING_LLM=true
# NEXT_MOVE_PLANNING_ENABLED=true
# NEXT_MOVE_PLANNING_MAX_TOKENS=384
# VERIFICATION_PLANNING_LLM=true
# VERIFICATION_PLANNING_ENABLED=true
# VERIFICATION_PLANNING_MAX_TOKENS=512
# ACCEPTANCE_CRITERIA_LLM=true
# ACCEPTANCE_CRITERIA_ENABLED=true
# ACCEPTANCE_CRITERIA_MAX_TOKENS=384
# TOOL_GUIDANCE_ENABLED=true
# TOOL_PARALLEL_ENABLED=true

# Semantic codebase search (retriv + Transformers.js)
SEMANTIC_SEARCH_ENABLED=true
SEMANTIC_SEARCH_MODEL=Xenova/all-MiniLM-L6-v2
# SEMANTIC_SEARCH_MAX_RESULTS=8
# SEMANTIC_SEARCH_MAX_FILE_SIZE=524288
# SEMANTIC_SEARCH_MAX_FILES=2500
